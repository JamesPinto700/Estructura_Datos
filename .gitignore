# Archivos compilados de Java
*.class

# Carpetas de build comunes
target/
bin/
out/

# Archivos de configuración de IDEs
.vscode/
.idea/
*.iml

# Dependencias de Node.js
node_modules/

# Cache de npm
.npm/

# Archivos temporales de Code Runner
tempCodeRunnerFile.js

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Archivos de entorno
.env

# Archivos de prueba o de uso personal (no forman parte de la entrega)
test_*.js
*_test.js
prueba_*.js

# Archivos temporales de Word/PowerPoint al tener el documento abierto
~$*.docx
~$*.pptx
